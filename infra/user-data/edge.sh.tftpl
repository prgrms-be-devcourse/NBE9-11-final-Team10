#!/bin/bash
set -e

dnf update -y
dnf install -y docker

systemctl enable docker
systemctl start docker

mkdir -p /usr/local/lib/docker/cli-plugins
curl -SL https://github.com/docker/compose/releases/download/v2.29.7/docker-compose-linux-x86_64 \
  -o /usr/local/lib/docker/cli-plugins/docker-compose
chmod +x /usr/local/lib/docker/cli-plugins/docker-compose

mkdir -p /dockerProjects/edge
mkdir -p /dockerProjects/npm/data
mkdir -p /dockerProjects/npm/letsencrypt

cat > /dockerProjects/edge/docker-compose.yml <<'COMPOSE'
${compose_yml}
COMPOSE

docker compose -f /dockerProjects/edge/docker-compose.yml up -d