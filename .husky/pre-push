#!/bin/sh

branch_name=$(git rev-parse --abbrev-ref HEAD)

valid_pattern='^(main|develop|feature/[a-z0-9._-]+|fix/[a-z0-9._-]+|hotfix/[a-z0-9._-]+|refactor/[a-z0-9._-]+|docs/[a-z0-9._-]+|chore/[a-z0-9._-]+|test/[a-z0-9._-]+)$'

if ! echo "$branch_name" | grep -Eq "$valid_pattern"; then
  echo ""
  echo "❌ Invalid branch name: $branch_name"
  echo ""
  echo "Allowed branch patterns:"
  echo "- main"
  echo "- develop"
  echo "- feature/{name}"
  echo "- fix/{name}"
  echo "- hotfix/{name}"
  echo "- refactor/{name}"
  echo "- docs/{name}"
  echo "- chore/{name}"
  echo "- test/{name}"
  echo ""
  echo "Branch names must be lowercase kebab-case."
  echo "Example: feature/auth, fix/transfer-validation, chore/github-actions"
  echo ""
  exit 1
fi